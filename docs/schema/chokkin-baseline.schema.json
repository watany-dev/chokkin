{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/watany-dev/chokkin/blob/main/docs/schema/chokkin-baseline.schema.json",
  "title": "chokkin baseline file",
  "type": "object",
  "additionalProperties": true,
  "required": ["chokkin_version", "generated_at", "issues"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Baseline schema version. Omitted files are v0.2 draft (`0`). v0.3 writes `1`."
    },
    "chokkin_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "pattern": "^unix:[0-9]+$"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["fingerprint", "code", "target"],
        "properties": {
          "fingerprint": { "type": "string" },
          "code": {
            "type": "string",
            "pattern": "^CHK00[1-9]|CHK010$"
          },
          "target": { "type": "string" }
        }
      }
    }
  }
}
