{
  "effortLevel": "high",
  "language": "japanese",
  "autoMemoryEnabled": false,
  "env": {
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1"
  },
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(cargo:*)",
      "Bash(git:*)",
      "Bash(uvx:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/stop-wrapup.sh"
          }
        ]
      }
    ]
  }
}
